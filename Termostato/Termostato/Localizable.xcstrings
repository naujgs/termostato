    "notification.title" : {
      "comment" : "Local notification title when device overheats",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iPhone Overheating"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iPhone sobrecalentándose"
          }
        }
      }
    },
    "notification.body" : {
      "comment" : "Local notification body (%@ is the thermal level name, e.g. Serious)",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thermal state: %@ — performance may be limited"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estado térmico: %@ — el rendimiento puede estar limitado"
          }
        }
      }
    },
    "notification.action_dismiss" : {
      "comment" : "Dismiss action on the thermal alert notification",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dismiss"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Descartar"
          }
