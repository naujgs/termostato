            "state" : "translated",
            "value" : "Serious"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Serio"
          }
        }
      }
    },
    "tooltip.app_cpu" : {
      "comment" : "Tooltip for App CPU metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU time used by this app across all cores. High values mean the app is working hard."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiempo de CPU usado por esta app en todos los núcleos. Valores altos indican que la app trabaja intensamente."
          }
        }
      }
    },
    "tooltip.app_memory" : {
      "comment" : "Tooltip for App Memory metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM currently occupied by this app (resident memory). iOS may terminate apps that use too much."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM ocupada actualmente por esta app (memoria residente). El sistema puede cerrar apps que usen demasiada."
          }
        }
      }
    },
    "tooltip.memory_active" : {
      "comment" : "Tooltip for Active Memory grid cell",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM currently being used by running apps and processes. High values are normal under load."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM en uso activo por apps y procesos en ejecución. Valores altos son normales bajo carga."
          }
        }
      }
    },
    "tooltip.memory_free" : {
      "comment" : "Tooltip for Free Memory grid cell",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Unallocated RAM plus speculative pages (prefetched file cache that iOS reclaims instantly). Near zero is normal — iOS fills spare pages proactively."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM sin asignar más páginas especulativas (caché de archivos precargada que iOS recupera al instante). Cerca de cero es normal."
          }
        }
      }
    },
    "tooltip.memory_inactive" : {
      "comment" : "Tooltip for Inactive Memory grid cell",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cold pages kept as cache plus the physical RAM used by iOS's VM compressor to store compressed pages. Both are reclaimable on demand."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Páginas frías en caché más la RAM física usada por el compresor de memoria de iOS. Ambas se pueden recuperar bajo demanda."
          }
        }
      }
    },
    "tooltip.memory_wired" : {
      "comment" : "Tooltip for Wired Memory grid cell",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kernel and system pages locked in RAM. Cannot be paged out — always reserved by iOS."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Páginas del kernel y del sistema bloqueadas en RAM. No pueden descargarse — siempre reservadas por iOS."
          }
        }
      }
    },
    "tooltip.sys_cpu" : {
      "comment" : "Tooltip for System CPU metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Total CPU usage across all apps and system processes on the device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uso total de CPU de todas las apps y procesos del sistema en el dispositivo."
          }
        }
      }
    },
    "tooltip.thermal_state" : {
      "comment" : "Tooltip for Thermal State badge",
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Device heat level reported by iOS. Nominal = cool, Fair = warm, Serious = hot (performance throttled), Critical = very hot (shutdown risk)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nivel de calor del dispositivo según iOS. Normal = frío, Regular = templado, Serio = caliente (rendimiento reducido), Crítico = muy caliente (riesgo de apagado)."
          }
        }
      }
    }
  },
  "version" : "1.0"
}