{
  "sourceLanguage" : "en",
  "strings" : {
    "tooltip.app_cpu" : {
      "comment" : "Tooltip for App CPU metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU time used by this app across all cores. High values mean the app is working hard."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tiempo de CPU usado por esta app en todos los núcleos. Valores altos indican que la app trabaja intensamente."
          }
        }
      }
    },
    "tooltip.sys_cpu" : {
      "comment" : "Tooltip for System CPU metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Total CPU usage across all apps and system processes on the device."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uso total de CPU de todas las apps y procesos del sistema en el dispositivo."
          }
        }
      }
    },
    "tooltip.app_memory" : {
      "comment" : "Tooltip for App Memory metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM currently occupied by this app (resident memory). iOS may terminate apps that use too much."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM ocupada actualmente por esta app (memoria residente). El sistema puede cerrar apps que usen demasiada."
          }
        }
      }
    },
    "tooltip.memory_free" : {
      "comment" : "Tooltip for Memory Free metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM available for apps right now. Low values may cause iOS to terminate background apps."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM disponible para apps en este momento. Valores bajos pueden hacer que el sistema cierre apps en segundo plano."
          }
        }
      }
    },
    "tooltip.memory_used" : {
      "comment" : "Tooltip for Memory Used metric card",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM currently in use by all apps and system processes combined."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RAM en uso actualmente por todas las apps y procesos del sistema combinados."
          }
        }
      }
    },
    "tooltip.thermal_state" : {
      "comment" : "Tooltip for Thermal State badge",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Device heat level reported by iOS. Nominal = cool, Fair = warm, Serious = hot (performance throttled), Critical = very hot (shutdown risk)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nivel de calor del dispositivo según iOS. Nominal = frío, Fair = templado, Serious = caliente (rendimiento reducido), Critical = muy caliente (riesgo de apagado)."
          }
        }
      }
    },
    "tab.thermal" : {
      "comment" : "Tab bar label for thermal state tab",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thermal"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Térmica"
          }
        }
      }
    },
    "tab.cpu" : {
      "comment" : "Tab bar label for CPU tab",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU"
          }
        }
      }
    },
    "tab.memory" : {
      "comment" : "Tab bar label for memory tab",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memory"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Memoria"
          }
        }
      }
    },
    "label.live" : {
      "comment" : "Live indicator pip inside the thermal badge",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "LIVE"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "EN VIVO"
          }
        }
      }
    },
    "label.pts" : {
      "comment" : "Abbreviation for data points count in chart header",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PTS"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "PTS"
          }
        }
      }
    },
    "chart.header" : {
      "comment" : "Chart section header label",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📊 Your Last Hour At A Glance"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "📊 Tu última hora de un vistazo"
          }
        }
      }
    },
    "chart.resolution" : {
      "comment" : "Chart time window and polling interval label",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "60 min · 10 s"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "60 min · 10 s"
          }
        }
      }
    },
    "chart.warming_up" : {
      "comment" : "Headline shown while waiting for first thermal reading",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Warming up..."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Calentando..."
          }
        }
      }
    },
    "chart.empty_hint" : {
      "comment" : "Subtext shown while waiting for first thermal reading",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Thermal data will appear here once the first reading arrives."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los datos térmicos aparecerán aquí cuando llegue la primera lectura."
          }
        }
      }
    },
    "chart.caption" : {
      "comment" : "Caption below the session history chart",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Session history (last 60 min)"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Historial de sesión (últimos 60 min)"
          }
        }
      }
    },
    "banner.notifications_disabled" : {
      "comment" : "Banner shown when notification permission is denied",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications disabled — tap to open Settings"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notificaciones desactivadas — toca para abrir Ajustes"
          }
        }
      }
    },
